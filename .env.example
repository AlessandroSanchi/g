# Configurazione Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Secret Key (CAMBIA IN PRODUZIONE!)
FLASK_SECRET_KEY=dev-secret-key-change-me

# Database
DATABASE_URL=sqlite:///app/instance/game.sqlite

# Server
SERVER_PORT=5002
SERVER_HOST=0.0.0.0

# Gioco - Configura la difficoltà
GAME_SPAWN_RATE=1.0
GAME_DIFFICULTY=normal
